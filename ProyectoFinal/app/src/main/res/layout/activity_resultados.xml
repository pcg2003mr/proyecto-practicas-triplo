<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/resultados"
    tools:context=".Resultados">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardViewLocalizacion"
        android:layout_width="174dp"
        android:layout_height="106dp"
        android:layout_marginStart="1dp"
        android:layout_marginEnd="1dp"
        android:layout_marginBottom="92dp"
        app:cardBackgroundColor="#03A9F4"
        app:cardCornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.929"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/textView2"
            android:layout_width="88dp"
            android:layout_height="73dp"
            android:layout_gravity="center|right"
            android:fontFamily="sans-serif-condensed"
            android:foregroundGravity="center"
            android:gravity="center"
            android:text="Descubre donde reciclar"
            android:textColor="#000000" />

        <ImageView
            android:id="@+id/imageView3"
            android:layout_width="95dp"
            android:layout_height="match_parent"
            android:foregroundGravity="center"
            app:srcCompat="@drawable/geolocalizacion" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardViewInicio3"
        android:layout_width="174dp"
        android:layout_height="106dp"
        android:layout_marginStart="1dp"
        android:layout_marginEnd="1dp"
        android:layout_marginBottom="93dp"
        app:cardBackgroundColor="#03A9F4"
        app:cardCornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.081"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/textView"
            android:layout_width="68dp"
            android:layout_height="60dp"
            android:layout_gravity="center|right"
            android:fontFamily="sans-serif-condensed"
            android:gravity="center"
            android:text="Volver al Inicio"
            android:textColor="#000000" />

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="112dp"
            android:layout_height="match_parent"
            app:srcCompat="@drawable/menu" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/textViewTitulo4"
        android:layout_width="300dp"
        android:layout_height="115dp"
        android:fontFamily="sans-serif-smallcaps"
        android:gravity="center"
        android:text="Páseme su Información"
        android:textSize="50sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.039" />

    <ListView
        android:id="@+id/ListViewResultados"
        android:layout_width="326dp"
        android:layout_height="291dp"
        android:layout_marginStart="42dp"
        android:layout_marginTop="81dp"
        android:layout_marginEnd="43dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewTitulo4" />
</androidx.constraintlayout.widget.ConstraintLayout>